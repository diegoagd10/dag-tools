{
  "name": "dag-tools",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch --tsconfig tsconfig.server.json src/index.ts",
    "build": "pnpm run typecheck && pnpm run build:css",
    "start": "pnpm run build:css && tsx --tsconfig tsconfig.server.json src/index.ts",
    "lint": "pnpm exec eslint",
    "typecheck": "tsc --noEmit -p tsconfig.server.json",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "sandcastle:build": "sandcastle docker build-image",
    "loop": "pnpm dlx tsx .sandcastle/main.mts",
    "build:css": "pnpm tailwindcss -i static/styles.src.css -o static/styles.css"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.5",
    "@tailwindcss/cli": "^4.3.1",
    "better-sqlite3": "^12.11.1",
    "hono": "^4.12.26",
    "js-yaml": "^4.2.0",
    "jszip": "^3.10.1",
    "nanoid": "^5.1.15",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "^0.10.0",
    "@playwright/test": "^1.61.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "eslint": "^9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  }
}
